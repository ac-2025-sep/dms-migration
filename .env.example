# Required Google Drive settings
GOOGLE_SERVICE_ACCOUNT_FILE=D:\path\to\google-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-root-folder-id

# Required Mayan EDMS settings
MAYAN_BASE_URL=https://mayan.example.com
MAYAN_API_TOKEN=your-mayan-api-token
MAYAN_DEFAULT_DOCUMENT_TYPE_ID=1

# Required local migration state
MANIFEST_PATH=state\migration_manifest.json
DOWNLOAD_TEMP_DIR=state\downloads
DRY_RUN=true

# Optional Google Workspace export mode.
# office: Docs -> .docx, Sheets -> .xlsx, Slides -> .pptx
# pdf: Docs, Sheets, and Slides -> .pdf
WORKSPACE_EXPORT_MODE=office

# Optional report/log paths
REPORT_JSON_PATH=state\migration_report.json
REPORT_CSV_PATH=state\migration_report.csv
LOG_PATH=migration.log

# Optional Mayan/API request behavior
REQUEST_TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
RETRY_MIN_SECONDS=1
RETRY_MAX_SECONDS=10

# Optional tag behavior
TAG_KEYWORD_LIMIT=5

# Optional Mayan metadata label mapping.
# Keys are internal migration metadata fields.
# Values are Mayan metadata type labels/names to write into.
MAYAN_METADATA_LABELS={"content_code":"content_code","channel_or_format":"channel_or_format","language":"language","section_code":"section_code","version":"version","document_stage":"document_stage","title":"title","original_filename":"original_filename","google_file_id":"google_file_id","google_drive_full_path":"google_drive_full_path","google_modified_time":"google_modified_time","google_mime_type":"google_mime_type","migration_timestamp":"migration_timestamp","source":"source"}
